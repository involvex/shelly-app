{
	"name": "@shelly/mobile",
	"version": "0.0.2",
	"private": true,
	"main": "expo-router/entry",
	"scripts": {
		"android": "expo run:android",
		"check": "bun run prebuild && bun run expo:check && bun run doctor",
		"deploy": "bunx expo export -p web && bunx eas-cli@latest deploy",
		"doctor": "bunx expo-doctor --verbose",
		"expo:check": "bunx expo install --check",
		"expo:prebuild": "bun run prebuild && expo prebuild",
		"format": "prettier . --write",
		"postinstall": "patch-package",
		"ios": "expo run:ios",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix",
		"prebuild": "bun run format && bun run lint:fix && bun run typecheck",
		"start": "expo start",
		"typecheck": "tsc --noEmit",
		"web": "expo start --web"
	},
	"dependencies": {
		"@babel/plugin-transform-react-jsx": "^7.28.6",
		"@bacons/apple-colors": "^0.0.8",
		"@dylankenneally/react-native-ssh-sftp": "^1.6.8",
		"@expo/vector-icons": "^15.1.1",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-icons": "^1.3.2",
		"@react-native-async-storage/async-storage": "2.2.0",
		"@react-native-menu/menu": "^2.0.0",
		"@react-navigation/native": "^7.1.33",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"babel-preset-expo": "~55.0.8",
		"class-variance-authority": "^0.7.0",
		"clsx": "^2.1.0",
		"expo": "^55.0.8",
		"expo-clipboard": "^55.0.9",
		"expo-constants": "~55.0.9",
		"expo-crypto": "~55.0.10",
		"expo-dev-client": "^55.0.18",
		"expo-device": "~55.0.10",
		"expo-font": "~55.0.4",
		"expo-linking": "~55.0.8",
		"expo-network": "~55.0.9",
		"expo-router": "~55.0.7",
		"expo-secure-store": "~55.0.9",
		"expo-splash-screen": "~55.0.12",
		"expo-status-bar": "~55.0.4",
		"expo-symbols": "~55.0.5",
		"expo-system-ui": "~55.0.10",
		"expo-vector-icons": "^10.0.1",
		"expo-web-browser": "~55.0.10",
		"nativewind": "^4.2.3",
		"next-themes": "^0.4.6",
		"react": "19.2.0",
		"react-dom": "19.2.0",
		"react-native": "0.83.2",
		"react-native-css-interop": "^0.2.3",
		"react-native-ios-context-menu": "^3.2.1",
		"react-native-ios-utilities": "^5.2.0",
		"react-native-reanimated": "4.2.1",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-screens": "~4.23.0",
		"react-native-tcp-socket": "^6.4.1",
		"react-native-text": "^1.2.2",
		"react-native-web": "^0.21.0",
		"react-native-webview": "13.16.0",
		"react-native-worklets": "0.7.2",
		"rn-icon-mapper": "^0.0.1",
		"tailwind-merge": "^2.2.1",
		"tailwindcss": "^3.4.0",
		"tailwindcss-animate": "^1.0.7",
		"zeego": "^3.0.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@types/react": "~19.2.10",
		"patch-package": "^8.0.0",
		"typescript": "~5.9.2"
	},
	"expo": {
		"doctor": {
			"reactNativeDirectoryCheck": {
				"enabled": true,
				"exclude": [
					"dist",
					"build",
					"node_modules",
					".expo",
					".expo-shared",
					"@dylankenneally/react-native-ssh-sftp",
					"react-native-tcp-socket"
				],
				"listUnknownPackages": true
			}
		}
	},
	"sponsor": {
		"url": "https://github.com/sponsors/involvex"
	}
}
